{
  "_comment_target": "Starter config for 8 GB VRAM cards (GTX 1070, RTX 2060/3060 8GB, RTX 4060 8GB, M1/M2 8GB unified). Rename to hybrid.config.json and `ollama pull` each model in local.models before starting the router.",
  "listen": {
    "host": "127.0.0.1"
  },
  "display": {
    "time_zone": "America/Toronto"
  },
  "local": {
    "model": "qwen2.5-coder:7b",
    "fast_model": "qwen2.5-coder:3b",
    "smart_routing": true,
    "models": [
      "qwen2.5-coder:7b",
      "qwen2.5-coder:3b",
      "llama3.2:3b"
    ],
    "cascadeQuality": false,
    "vram_gb": 8,
    "shadow_eval_enabled": false,
    "shadow_eval_model": "qwen2.5-coder:3b"
  },
  "routing": {
    "mode": "hybrid",
    "_comment_tokenThreshold": "Lower than the 16 GB default (32000). An 8 GB pool can't hold a big model + a long transcript, so push anything over 16k to cloud early rather than choke Ollama.",
    "tokenThreshold": 16000,
    "fileReadThreshold": 6,
    "keywords": [
      "architect",
      "security audit",
      "audit",
      "design pattern",
      "race condition",
      "performance optim",
      "system design",
      "data model",
      "api design",
      "deep reason",
      "vulnerabilit",
      "threat model"
    ],
    "alwaysLocalTerms": [],
    "forceLocalIfPrivacyTerms": false,
    "privacyCustomTerms": [],
    "quotaRecoveryMinutes": 60
  },
  "privacy": {
    "cloud_redaction": {
      "enabled": false,
      "redact_tool_results": true,
      "redact_paths": true,
      "redact_urls": true,
      "redact_emails": true,
      "redact_secrets": true,
      "redact_ids": true,
      "redact_identifiers": false,
      "custom_terms": []
    },
    "project_obfuscation": {
      "enabled": true,
      "project_terms": [],
      "alias_prefix": "proj",
      "auto_detect_filenames": true,
      "auto_detect_identifiers": false,
      "preserve_extensions": true,
      "scan_system_prompt": true,
      "scan_tool_results": true
    }
  }
}
